# Supabase project URL (Project Settings → API → Project URL)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key (Project Settings → API → service_role).
# Must be the SERVICE ROLE key, not the anon key — the backend bypasses
# RLS and writes/reads any session row by id. Keep this secret; never
# bundle it into the frontend.
SUPABASE_KEY=your-service-role-key

# Comma-separated list of additional CORS origins to allow.
# Localhost dev is always allowed; in prod set this to the GitHub Pages
# origin, e.g. https://nemanja5199.github.io
CORS_ALLOWED_ORIGINS=
